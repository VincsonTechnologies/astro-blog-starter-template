---
---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Vincson Technologies</title>

<style>
:root{
--bg:#05050a;
--bg-soft:#0d0816;
--panel:#130c1f;
--panel-2:#171022;
--text:#ffffff;
--muted:#d8d0eb;
--muted2:#b8afcf;
--purple:#2b1740;
--purple2:#462263;
--border:rgba(255,255,255,.08);
}

*{
box-sizing:border-box;
}

html{
scroll-behavior:smooth;
}

body{
margin:0;
font-family:Arial,sans-serif;
color:var(--text);
background:var(--bg);
overflow-x:hidden;
}

.parallax-bg{
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
z-index:-1;
background:
linear-gradient(rgba(18,8,38,.60),rgba(10,5,20,.75)),
url('/cloud-bg.jpg');
background-size:cover;
background-position:center;
background-repeat:no-repeat;
}

.container{
max-width:1220px;
margin:auto;
padding:30px 20px 90px;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:16px;
padding-bottom:24px;
}

.brand{
font-size:24px;
font-weight:700;
letter-spacing:.2px;
}

nav{
display:flex;
gap:12px;
flex-wrap:wrap;
}

.nav-link{
padding:12px 18px;
border-radius:12px;
background:rgba(26,16,38,.88);
border:1px solid var(--border);
text-decoration:none;
color:white;
font-weight:600;
transition:transform .22s ease, border-color .22s ease, background .22s ease;
}

.nav-link:hover{
transform:translateY(-2px);
border-color:rgba(170,120,255,.22);
background:rgba(34,20,48,.92);
}

.hero{
display:grid;
grid-template-columns:1fr 1fr;
gap:44px;
align-items:center;
min-height:82vh;
}

.hero-copy{
max-width:620px;
}

.eyebrow{
display:inline-block;
font-size:13px;
letter-spacing:2px;
text-transform:uppercase;
color:#ccb2ff;
margin-bottom:18px;
}

.hero h1{
font-size:clamp(42px,6vw,72px);
line-height:1.02;
margin:0 0 20px;
}

.hero span{
color:#b975ff;
}

.hero p{
color:var(--muted);
line-height:1.8;
font-size:19px;
margin:0 0 30px;
}

.hero-buttons{
display:flex;
gap:14px;
flex-wrap:wrap;
}

.btn{
padding:14px 24px;
border-radius:12px;
text-decoration:none;
font-weight:700;
display:inline-block;
transition:transform .22s ease, border-color .22s ease, background .22s ease, box-shadow .22s ease;
}

.btn-primary{
background:linear-gradient(135deg,#2b1740,#462263);
border:1px solid rgba(120,70,200,.30);
color:white;
box-shadow:inset 0 1px 0 rgba(255,255,255,.04);
}

.btn-primary:hover{
transform:translateY(-2px);
box-shadow:0 8px 24px rgba(0,0,0,.25);
}

.btn-secondary{
background:rgba(26,16,38,.88);
border:1px solid rgba(255,255,255,.10);
color:white;
}

.btn-secondary:hover{
transform:translateY(-2px);
border-color:rgba(170,120,255,.22);
}

.visual-card{
padding:20px;
border-radius:24px;
background:rgba(10,8,18,.72);
border:1px solid var(--border);
backdrop-filter:blur(10px);
box-shadow:0 24px 60px rgba(0,0,0,.38);
transition:transform .28s ease, box-shadow .28s ease, border-color .28s ease;
}

.visual-card:hover{
transform:translateY(-6px);
box-shadow:0 30px 70px rgba(0,0,0,.45);
border-color:rgba(180,120,255,.16);
}

.lock-image{
width:100%;
height:420px;
object-fit:cover;
border-radius:18px;
display:block;
}

.section{
padding:84px 0 10px;
}

.section-header{
max-width:820px;
margin:0 auto 30px;
text-align:center;
}

.section h2{
font-size:36px;
margin:0 0 12px;
}

.section-header p{
margin:0;
line-height:1.75;
color:var(--muted2);
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.card{
padding:24px;
border-radius:20px;
background:linear-gradient(180deg, rgba(19,12,31,.96), rgba(14,10,24,.96));
border:1px solid var(--border);
transition:transform .22s ease, border-color .22s ease, background .22s ease;
}

.card:hover{
transform:translateY(-4px);
border-color:rgba(170,120,255,.16);
background:linear-gradient(180deg, rgba(24,15,38,.98), rgba(16,11,28,.98));
}

.card-dot{
width:14px;
height:14px;
border-radius:50%;
background:linear-gradient(135deg,#8f4fff,#c17aff);
margin-bottom:14px;
box-shadow:0 0 16px rgba(145,80,255,.28);
}

.card h3{
margin:0 0 10px;
font-size:21px;
}

.card p{
margin:0;
color:#d4cee6;
line-height:1.7;
}

.panel{
padding:34px;
border-radius:24px;
background:rgba(14,10,24,.82);
border:1px solid var(--border);
}

.center{
text-align:center;
}

.footer{
padding:60px 0 10px;
text-align:center;
color:#aaa1c5;
font-size:14px;
}

.reveal{
opacity:0;
transform:translateY(18px);
transition:opacity .6s ease, transform .6s ease;
}

.reveal.is-visible{
opacity:1;
transform:translateY(0);
}

@media(max-width:900px){
.hero{
grid-template-columns:1fr;
text-align:center;
gap:28px;
}

.hero-copy{
max-width:800px;
margin:auto;
}

.hero-buttons{
justify-content:center;
}

header{
justify-content:center;
}

.brand{
width:100%;
text-align:center;
}
}

@media(max-width:640px){
.hero h1{
font-size:42px;
}

.hero p{
font-size:18px;
}

nav{
justify-content:center;
}
}
</style>
</head>

<body>

<div class="parallax-bg"></div>

<div class="container">

<header>
<div class="brand">Vincson Technologies</div>

<nav>
<a href="#services" class="nav-link">Services</a>
<a href="#who" class="nav-link">Who We Help</a>
<a href="#why" class="nav-link">Why Vincson Technologies</a>
<a href="#alerts" class="nav-link">Alerts</a>
<a href="#contact" class="nav-link">Contact</a>
</nav>
</header>

<section class="hero">
<div class="hero-copy reveal">
<div class="eyebrow">AI-Powered Security</div>

<h1>Cybersecurity for <span>Small Businesses</span></h1>

<p>
Vincson Technologies helps businesses reduce risk with modern security strategies, improved visibility, and real protection against evolving cyber threats.
</p>

<div class="hero-buttons">
<a href="#contact" class="btn btn-primary">Request Consultation</a>
<a href="#services" class="btn btn-secondary">View Services</a>
</div>
</div>

<div class="visual-card reveal">
<img src="/lock-visual.jpg" class="lock-image" alt="Cybersecurity visual">
</div>
</section>

<section id="services" class="section reveal">
<div class="section-header">
<h2>Services</h2>
<p>Focused cybersecurity support designed to help businesses strengthen defenses, reduce exposure, and improve resilience.</p>
</div>

<div class="cards">
<div class="card">
<div class="card-dot"></div>
<h3>Threat Monitoring</h3>
<p>Detect suspicious activity earlier and improve visibility into potential security issues before they escalate.</p>
</div>

<div class="card">
<div class="card-dot"></div>
<h3>Security Assessments</h3>
<p>Identify weaknesses across systems, user accounts, devices, and access points that attackers may exploit.</p>
</div>

<div class="card">
<div class="card-dot"></div>
<h3>AI Security</h3>
<p>Use modern defensive thinking and AI-enhanced workflows to keep pace with increasingly automated threats.</p>
</div>
</div>
</section>

<section id="who" class="section reveal">
<div class="section-header">
<h2>Who We Help</h2>
<p>Built for organizations that need stronger security without enterprise-level complexity.</p>
</div>

<div class="cards">
<div class="card">
<div class="card-dot"></div>
<h3>Small Businesses</h3>
<p>Protect operations, devices, accounts, and business systems without the overhead of a large internal security team.</p>
</div>

<div class="card">
<div class="card-dot"></div>
<h3>Offices</h3>
<p>Help secure business communications, cloud platforms, and sensitive client or internal information.</p>
</div>

<div class="card">
<div class="card-dot"></div>
<h3>Growing Companies</h3>
<p>Scale more safely with stronger processes, better visibility, and more intentional cyber risk reduction.</p>
</div>
</div>
</section>

<section id="why" class="section reveal">
<div class="panel">
<div class="section-header">
<h2>Why Vincson Technologies</h2>
<p>A practical approach focused on real business protection, modern threats, and clear security value.</p>
</div>

<div class="cards">
<div class="card">
<div class="card-dot"></div>
<h3>Practical Security</h3>
<p>No fluff. Just meaningful security improvements designed to reduce risk and strengthen resilience.</p>
</div>

<div class="card">
<div class="card-dot"></div>
<h3>Modern Defense</h3>
<p>Built around the way attackers operate today, including fast-moving, cloud-based, and AI-influenced threats.</p>
</div>

<div class="card">
<div class="card-dot"></div>
<h3>Focused on You</h3>
<p>Security support tailored to business realities instead of generic enterprise recommendations.</p>
</div>
</div>
</div>
</section>

<section id="alerts" class="section reveal">
<div class="panel center">
<div class="section-header">
<h2>Threat Alerts</h2>
<p>Follow Vincson Technologies for cybersecurity tips, awareness content, and current threat-focused updates.</p>
</div>

<a href="https://instagram.com/vincsontechnologies" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
Follow on Instagram
</a>
</div>
</section>

<section id="contact" class="section reveal">
<div class="panel center">
<div class="section-header">
<h2>Contact</h2>
<p>Start the conversation and find out how Vincson Technologies can help strengthen your security posture.</p>
</div>

<a href="mailto:VincsonTechnologies@gmail.com" class="btn btn-primary">
Contact Vincson Technologies
</a>
</div>
</section>

<div class="footer">
© 2026 Vincson Technologies
</div>

</div>

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry) => {
    if (entry.isIntersecting) {
      entry.target.classList.add('is-visible');
    }
  });
}, { threshold: 0.12 });

document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>

</body>
</html>
