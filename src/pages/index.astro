<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Vincson Technologies</title>

<style>
:root{
--purple:#7b2cff;
--purple2:#b56cff;
--text:#fff;
}

*{
box-sizing:border-box;
}

html{
scroll-behavior:smooth;
}

body{
margin:0;
font-family:Arial,sans-serif;
color:white;
overflow-x:hidden;
background:#05050a;
}

.parallax-bg{
position:fixed;
inset:0;
z-index:-3;
background:
linear-gradient(
rgba(30,0,70,.62),
rgba(65,0,110,.72)
),
url('/cloud-bg.jpg');
background-size:cover;
background-position:center center;
background-repeat:no-repeat;
animation:drift 28s ease-in-out infinite alternate;
transform:scale(1.08);
}

@keyframes drift{
0%{
transform:scale(1.08) translate3d(0px,0px,0px);
}
50%{
transform:scale(1.12) translate3d(-18px,-10px,0px);
}
100%{
transform:scale(1.08) translate3d(18px,10px,0px);
}
}

.center-pulse{
position:fixed;
left:50%;
top:36%;
transform:translate(-50%,-50%);
width:340px;
height:340px;
border-radius:50%;
pointer-events:none;
z-index:-2;
background:
radial-gradient(
circle,
rgba(42,12,72,.18) 0%,
rgba(28,8,52,.10) 35%,
rgba(16,5,28,.05) 55%,
transparent 72%
);
filter:blur(20px);
animation:pulseGlow 4.8s ease-in-out infinite;
}

@keyframes pulseGlow{
0%,100%{
transform:translate(-50%,-50%) scale(.96);
opacity:.72;
}
50%{
transform:translate(-50%,-50%) scale(1.08);
opacity:1;
}
}

.page-glow{
position:fixed;
top:-140px;
right:-140px;
width:420px;
height:420px;
border-radius:50%;
background:
radial-gradient(
circle,
rgba(35,12,58,.22),
rgba(18,6,32,.10),
transparent 70%
);
filter:blur(42px);
z-index:-1;
pointer-events:none;
}

.container{
max-width:1180px;
margin:auto;
padding:32px 20px 90px;
position:relative;
z-index:2;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:18px;
padding-bottom:28px;
}

.brand{
font-size:22px;
font-weight:700;
}

nav{
display:flex;
gap:12px;
flex-wrap:wrap;
}

.glow-link{
transition:
transform .25s ease,
box-shadow .25s ease;
}

.glow-link:hover{
transform:translateY(-2px);
box-shadow:
0 0 18px rgba(160,95,255,.45),
0 0 34px rgba(160,95,255,.20);
}

.glow-link:active{
transform:scale(.98);
box-shadow:
0 0 28px rgba(190,130,255,.75);
}

.nav-link{
text-decoration:none;
color:white;
padding:12px 18px;
border-radius:12px;
font-weight:700;
border:1px solid rgba(255,255,255,.12);
background:rgba(255,255,255,.05);
backdrop-filter:blur(8px);
}

.hero{
min-height:78vh;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
}

.hero-copy{
max-width:860px;
}

.eyebrow{
letter-spacing:2px;
text-transform:uppercase;
font-size:13px;
color:#d4bfff;
margin-bottom:20px;
}

.hero-title{
font-size:clamp(42px,6vw,68px);
line-height:1.05;
margin:0 0 22px;
}

.hero-text{
font-size:20px;
line-height:1.7;
max-width:760px;
margin:0 auto 34px;
color:#e0daf6;
}

.hero-buttons{
display:flex;
justify-content:center;
flex-wrap:wrap;
gap:14px;
}

.btn-primary,
.btn-secondary{
display:inline-block;
padding:14px 24px;
border-radius:12px;
text-decoration:none;
font-weight:700;
}

.btn-primary{
background:linear-gradient(135deg,var(--purple),var(--purple2));
color:white;
}

.btn-secondary{
border:1px solid rgba(255,255,255,.14);
background:rgba(255,255,255,.05);
color:white;
}

.section{
padding:80px 0 20px;
}

.section-title{
font-size:34px;
text-align:center;
margin-bottom:14px;
}

.section-text{
text-align:center;
max-width:760px;
margin:0 auto 30px;
line-height:1.7;
color:#d9d3ef;
}

.grid3{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
gap:20px;
}

.grid4{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
}

.card{
padding:24px;
border-radius:18px;
background:rgba(255,255,255,.055);
border:1px solid rgba(255,255,255,.08);
backdrop-filter:blur(10px);
}

.card h3{
margin-top:0;
margin-bottom:12px;
}

.card p{
line-height:1.7;
color:#ddd7f1;
margin:0;
}

.panel{
padding:34px;
border-radius:22px;
background:rgba(255,255,255,.045);
border:1px solid rgba(255,255,255,.08);
backdrop-filter:blur(12px);
}

.center{
text-align:center;
}

footer{
padding:60px 0 10px;
text-align:center;
color:#aaa1c5;
}

@media(max-width:640px){
nav{
justify-content:center;
}

.hero-title{
font-size:42px;
}

.hero-text{
font-size:18px;
}
}
</style>
</head>

