---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Vincson Technologies</title>

<style>
:root{
--bg-1:#040407;
--bg-2:#090512;
--bg-3:#12091f;
--text:#ffffff;
--muted:#d8d0eb;
--muted-2:#d3cae8;
--purple:#7b2cff;
--purple-2:#b56cff;
}

*{
box-sizing:border-box;
}

html{
scroll-behavior:smooth;
}

body{
margin:0;
font-family:Arial,sans-serif;
color:var(--text);
background:
radial-gradient(circle at 15% 20%, rgba(125,55,255,.14), transparent 30%),
radial-gradient(circle at 85% 70%, rgba(95,35,255,.10), transparent 28%),
linear-gradient(135deg,var(--bg-1) 0%,var(--bg-2) 45%,var(--bg-3) 100%);
overflow-x:hidden;
}

.page-glow{
position:fixed;
top:-140px;
right:-140px;
width:440px;
height:440px;
border-radius:50%;
background:radial-gradient(circle,rgba(165,100,255,.16),transparent 68%);
filter:blur(22px);
pointer-events:none;
z-index:0;
}

.container{
position:relative;
z-index:1;
max-width:1180px;
margin:0 auto;
padding:32px 20px 80px;
}

.site-header{
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:18px;
padding:8px 0 30px;
}

.brand{
font-size:22px;
font-weight:700;
letter-spacing:.4px;
}

.nav{
display:flex;
gap:12px;
flex-wrap:wrap;
font-size:14px;
}

.glow-link{
transition:transform .25s ease, box-shadow .25s ease;
}

.glow-link:hover{
box-shadow:
0 0 18px rgba(160,95,255,.45),
0 0 36px rgba(160,95,255,.22);
transform:translateY(-2px);
}

.glow-link:active{
box-shadow:
0 0 28px rgba(190,130,255,.72);
transform:scale(.98);
}

.nav-link{
color:white;
text-decoration:none;
padding:12px 18px;
border-radius:12px;
font-weight:700;
display:inline-block;
border:1px solid rgba(255,255,255,.12);
background:rgba(255,255,255,.04);
}

.hero{
min-height:78vh;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
padding:20px 0 30px;
}

.hero-copy{
max-width:860px;
}

.eyebrow{
display:inline-block;
font-size:13px;
text-transform:uppercase;
letter-spacing:2px;
color:#ceb5ff;
margin-bottom:18px;
}

.hero-title{
font-size:clamp(38px,6vw,68px);
line-height:1.05;
margin:0 0 20px;
}

.hero-text{
font-size:20px;
line-height:1.7;
color:#ddd6f3;
max-width:760px;
margin:0 auto 34px;
}

.hero-buttons{
display:flex;
gap:14px;
flex-wrap:wrap;
justify-content:center;
}

.btn-primary,
.btn-secondary{
text-decoration:none;
padding:14px 24px;
border-radius:12px;
font-weight:700;
display:inline-block;
}

.btn-primary{
background:linear-gradient(135deg,var(--purple),var(--purple-2));
color:white;
}

.btn-secondary{
color:white;
border:1px solid rgba(255,255,255,.12);
background:rgba(255,255,255,.04);
}

.section{
padding:80px 0 20px;
}

.section-title{
font-size:34px;
margin:0 0 12px;
text-align:center;
}

.section-text{
text-align:center;
color:var(--muted-2);
max-width:760px;
margin:0 auto 30px;
line-height:1.7;
}

.grid-3,
.grid-4{
display:grid;
gap:20px;
}

.grid-3{
grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
}

.grid-4{
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
}

.card,
.card-soft{
border-radius:18px;
padding:24px;
}

.card{
background:rgba(255,255,255,.05);
border:1px solid rgba(255,255,255,.08);
}

.card-soft{
background:rgba(255,255,255,.04);
border:1px solid rgba(255,255,255,.08);
}

.card h3,
.card-soft h3{
margin:0 0 12px;
font-size:20px;
}

.card p,
.card-soft p{
margin:0;
color:var(--muted);
line-height:1.7;
}

.panel{
background:rgba(255,255,255,.04);
border:1px solid rgba(255,255,255,.08);
border-radius:22px;
padding:34px;
}

.center{
text-align:center;
}

.footer{
padding:50px 0 10px;
text-align:center;
color:#9f96b7;
font-size:14px;
}

@media(max-width:980px){
.site-header{
justify-content:center;
}
}

@media(max-width:640px){
.container{
padding:24px 16px 70px;
}

.nav{
justify-content:center;
}

.hero-title{
font-size:42px;
}

.hero-text{
font-size:18px;
}

.section-title{
font-size:30px;
}
}
</style>
</head>

