---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vincson Technologies</title>

    <style>
      :root {
        --bg-1: #05050a;
        --bg-2: #0b0614;
        --bg-3: #120a22;
        --text: #ffffff;
        --muted: #d8d0eb;
        --muted-2: #d3cae8;
        --purple: #7b2cff;
        --purple-2: #a855f7;
        --purple-soft: rgba(140, 80, 255, 0.45);
        --card: rgba(255, 255, 255, 0.05);
        --card-border: rgba(255, 255, 255, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Arial, sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at 15% 20%, rgba(125, 55, 255, 0.18), transparent 30%),
          radial-gradient(circle at 85% 70%, rgba(95, 35, 255, 0.14), transparent 30%),
          linear-gradient(135deg, var(--bg-1) 0%, var(--bg-2) 45%, var(--bg-3) 100%);
        overflow-x: hidden;
      }

      .page-grid {
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
        z-index: 0;
      }

      .page-glow {
        position: fixed;
        top: -120px;
        right: -120px;
        width: 420px;
        height: 420px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(140,80,255,.22), transparent 65%);
        filter: blur(20px);
        pointer-events: none;
        z-index: 0;
      }

      .container {
        position: relative;
        z-index: 1;
        max-width: 1150px;
        margin: 0 auto;
        padding: 32px 20px 80px;
      }

      .site-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        padding: 8px 0 30px;
      }

      .brand {
        font-size: 22px;
        font-weight: 700;
        letter-spacing: .4px;
      }

      .nav {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
        font-size: 14px;
      }

      .glow-link {
        transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease, color 0.25s ease;
      }

      .glow-link:hover {
        box-shadow:
          0 0 18px rgba(140, 80, 255, 0.45),
          0 0 36px rgba(140, 80, 255, 0.25);
        transform: translateY(-2px);
      }

      .glow-link:active {
        box-shadow:
          0 0 28px rgba(170, 100, 255, 0.7);
        transform: scale(0.98);
      }

      .nav-link {
        color: #d8cfff;
        text-decoration: none;
        padding: 6px 8px;
        border-radius: 8px;
      }

      .hero {
        min-height: 82vh;
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        align-items: center;
        gap: 28px;
        padding: 10px 0 30px;
      }

      .hero-copy {
        max-width: 620px;
      }

      .eyebrow {
        display: inline-block;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #bca7ff;
        margin-bottom: 18px;
      }

      .hero-title {
        font-size: clamp(38px, 6vw, 68px);
        line-height: 1.05;
        margin: 0 0 20px;
      }

      .hero-text {
        font-size: 20px;
        line-height: 1.7;
        color: #ddd6f3;
        max-width: 760px;
        margin: 0 0 34px;
      }

      .hero-buttons {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
      }

      .btn-primary,
      .btn-secondary {
        text-decoration: none;
        padding: 14px 24px;
        border-radius: 12px;
        font-weight: 700;
        display: inline-block;
      }

      .btn-primary {
        background: linear-gradient(135deg, var(--purple), var(--purple-2));
        color: white;
      }

      .btn-secondary {
        color: white;
        border: 1px solid rgba(255,255,255,.12);
        background: rgba(255,255,255,.04);
      }

      .hero-visual {
        position: relative;
        min-height: 560px;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: visible;
      }

      .hero-stars {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 20% 20%, rgba(255,255,255,.9) 0 1px, transparent 2px),
          radial-gradient(circle at 80% 15%, rgba(255,255,255,.7) 0 1px, transparent 2px),
          radial-gradient(circle at 70% 40%, rgba(255,255,255,.6) 0 1px, transparent 2px),
          radial-gradient(circle at 35% 65%, rgba(255,255,255,.7) 0 1px, transparent 2px),
          radial-gradient(circle at 85% 80%, rgba(255,255,255,.85) 0 1px, transparent 2px),
          radial-gradient(circle at 10% 75%, rgba(255,255,255,.75) 0 1px, transparent 2px);
        opacity: .5;
        filter: blur(.3px);
        animation: twinkle 6s ease-in-out infinite alternate;
        pointer-events: none;
      }

      @keyframes twinkle {
        from { opacity: .35; }
        to { opacity: .7; }
      }

      .globe-wrap {
        position: relative;
        width: 470px;
        height: 470px;
        display: flex;
        align-items: center;
        justify-content: center;
        filter: drop-shadow(0 0 30px rgba(92, 166, 255, 0.16));
      }

      .globe-aura {
        position: absolute;
        width: 520px;
        height: 520px;
        border-radius: 50%;
        background:
          radial-gradient(circle, rgba(115, 180, 255, .12) 0%, rgba(115, 180, 255, .08) 35%, transparent 70%);
        filter: blur(20px);
        animation: pulseAura 4.8s ease-in-out infinite;
      }

      @keyframes pulseAura {
        0%, 100% { transform: scale(0.98); opacity: .85; }
        50% { transform: scale(1.03); opacity: 1; }
      }

      .globe {
        position: relative;
        width: 360px;
        height: 360px;
        border-radius: 50%;
        background:
          radial-gradient(circle at 30% 30%, rgba(184, 230, 255, .65), rgba(44, 112, 194, .12) 34%, rgba(4, 18, 40, .25) 58%, rgba(0,0,0,.1) 100%),
          radial-gradient(circle at 55% 45%, rgba(110, 207, 255, .18), transparent 52%),
          linear-gradient(135deg, rgba(10, 26, 58, .85), rgba(3, 14, 30, .95));
        border: 1px solid rgba(170, 230, 255, .35);
        box-shadow:
          inset 0 0 45px rgba(160, 220, 255, .12),
          0 0 36px rgba(95, 184, 255, .18);
        overflow: hidden;
        animation: globeSpin 26s linear infinite;
      }

      @keyframes globeSpin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      .globe::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background:
          repeating-linear-gradient(
            90deg,
            rgba(150, 235, 255, 0.00) 0px,
            rgba(150, 235, 255, 0.00) 14px,
            rgba(150, 235, 255, 0.08) 15px,
            rgba(150, 235, 255, 0.00) 16px
          ),
          repeating-linear-gradient(
            0deg,
            rgba(150, 235, 255, 0.00) 0px,
            rgba(150, 235, 255, 0.00) 14px,
            rgba(150, 235, 255, 0.06) 15px,
            rgba(150, 235, 255, 0.00) 16px
          );
        mix-blend-mode: screen;
        opacity: .65;
      }

      .globe::after {
        content: "";
        position: absolute;
        inset: 10%;
        border-radius: 50%;
        background:
          radial-gradient(circle at 40% 50%, rgba(189, 239, 255, .85) 0 1px, transparent 2px),
          radial-gradient(circle at 58% 32%, rgba(189, 239, 255, .85) 0 1.3px, transparent 2px),
          radial-gradient(circle at 62% 58%, rgba(189, 239, 255, .85) 0 1px, transparent 2px),
          radial-gradient(circle at 35% 28%, rgba(189, 239, 255, .85) 0 1px, transparent 2px),
          radial-gradient(circle at 70% 40%, rgba(189, 239, 255, .85) 0 1px, transparent 2px),
          radial-gradient(circle at 48% 72%, rgba(189, 239, 255, .85) 0 1px, transparent 2px);
        opacity: .9;
        animation: dotsSpin 12s linear infinite reverse;
      }

      @keyframes dotsSpin {
        from { transform: rotate(0deg) scale(1); }
        to { transform: rotate(360deg) scale(1); }
      }

      .continent {
        position: absolute;
        background: rgba(188, 239, 255, .72);
        filter: blur(1px);
        opacity: .78;
      }

      .continent.africa {
        width: 90px;
        height: 120px;
        left: 166px;
        top: 108px;
        clip-path: polygon(36% 0%, 58% 8%, 62% 24%, 72% 40%, 68% 58%, 76% 75%, 62% 96%, 48% 86%, 40% 66%, 28% 54%, 18% 34%, 24% 16%);
      }

      .continent.europe {
        width: 72px;
        height: 52px;
        left: 164px;
        top: 78px;
        clip-path: polygon(14% 44%, 34% 18%, 64% 10%, 88% 24%, 80% 50%, 60% 58%, 44% 76%, 22% 70%, 8% 56%);
      }

      .continent.middle-east {
        width: 58px;
        height: 40px;
        left: 218px;
        top: 112px;
        clip-path: polygon(0% 42%, 24% 18%, 50% 8%, 92% 20%, 100% 42%, 72% 66%, 32% 76%, 10% 58%);
      }

      .continent.india {
        width: 40px;
        height: 44px;
        left: 250px;
        top: 132px;
        clip-path: polygon(24% 0%, 70% 10%, 84% 44%, 60% 100%, 30% 86%, 14% 42%);
      }

      .continent.madagascar {
        width: 18px;
        height: 34px;
        left: 246px;
        top: 224px;
        clip-path: polygon(40% 0%, 72% 18%, 64% 100%, 20% 80%, 8% 28%);
      }

      .globe-highlight {
        position: absolute;
        width: 120px;
        height: 120px;
        left: 54px;
        top: 54px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,255,.48), rgba(255,255,255,.12) 45%, transparent 72%);
        filter: blur(5px);
        opacity: .75;
      }

      .orbit {
        position: absolute;
        border: 2px solid rgba(179, 236, 255, 0.58);
        border-radius: 50%;
        box-shadow: 0 0 18px rgba(120, 200, 255, 0.18);
        pointer-events: none;
      }

      .orbit::after {
        content: "";
        position: absolute;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,255,.98) 0%, rgba(163,224,255,.95) 45%, rgba(163,224,255,.15) 100%);
        box-shadow: 0 0 16px rgba(165, 230, 255, 0.7);
      }

      .orbit-one {
        width: 430px;
        height: 145px;
        animation: orbitSpin 10s linear infinite;
      }

      .orbit-one::after {
        top: 8px;
        left: 52px;
      }

      .orbit-two {
        width: 440px;
        height: 180px;
        transform: rotate(58deg);
        animation: orbitSpin 13s linear infinite reverse;
      }

      .orbit-two::after {
        bottom: 16px;
        right: 84px;
      }

      .orbit-three {
        width: 448px;
        height: 120px;
        transform: rotate(-24deg);
        animation: orbitSpin 11s linear infinite;
      }

      .orbit-three::after {
        top: 24px;
        right: 58px;
      }

      .orbit-four {
        width: 392px;
        height: 250px;
        transform: rotate(90deg);
        animation: orbitSpin 15s linear infinite reverse;
        opacity: .85;
      }

      .orbit-four::after {
        left: 66px;
        top: 34px;
      }

      .orbit-five {
        width: 330px;
        height: 330px;
        transform: rotate(20deg);
        border-color: rgba(179,236,255,0.28);
        animation: orbitSpin 18s linear infinite;
      }

      .orbit-five::after {
        right: 52px;
        top: 42px;
      }

      @keyframes orbitSpin {
        from { transform: rotate(var(--start-rotation, 0deg)); }
        to { transform: rotate(calc(var(--start-rotation, 0deg) + 360deg)); }
      }

      .orbit-one { --start-rotation: 0deg; }
      .orbit-two { --start-rotation: 58deg; }
      .orbit-three { --start-rotation: -24deg; }
      .orbit-four { --start-rotation: 90deg; }
      .orbit-five { --start-rotation: 20deg; }

      .data-line {
        position: absolute;
        height: 2px;
        background: linear-gradient(90deg, transparent, rgba(185, 240, 255, .95), transparent);
        transform-origin: left center;
        opacity: .85;
        filter: blur(.2px);
        pointer-events: none;
      }

      .data-line::after {
        content: "";
        position: absolute;
        top: 50%;
        right: 18%;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        transform: translateY(-50%);
        background: rgba(255,255,255,.95);
        box-shadow: 0 0 16px rgba(165, 230, 255, 0.8);
        animation: pulseDot 1.5s ease-in-out infinite;
      }

      @keyframes pulseDot {
        0%, 100% { transform: translateY(-50%) scale(0.9); opacity: .75; }
        50% { transform: translateY(-50%) scale(1.15); opacity: 1; }
      }

      .line-1 {
        width: 305px;
        top: 154px;
        left: 94px;
        transform: rotate(15deg);
        animation: lineShift1 4.6s ease-in-out infinite;
      }

      .line-2 {
        width: 310px;
        top: 220px;
        left: 84px;
        transform: rotate(-18deg);
        animation: lineShift2 5.2s ease-in-out infinite;
      }

      .line-3 {
        width: 250px;
        top: 276px;
        left: 126px;
        transform: rotate(26deg);
        animation: lineShift3 4.9s ease-in-out infinite;
      }

      @keyframes lineShift1 {
        0%, 100% { transform: rotate(15deg) translateX(0px); opacity: .7; }
        50% { transform: rotate(15deg) translateX(8px); opacity: 1; }
      }

      @keyframes lineShift2 {
        0%, 100% { transform: rotate(-18deg) translateX(0px); opacity: .72; }
        50% { transform: rotate(-18deg) translateX(-10px); opacity: 1; }
      }

      @keyframes lineShift3 {
        0%, 100% { transform: rotate(26deg) translateX(0px); opacity: .68; }
        50% { transform: rotate(26deg) translateX(10px); opacity: 1; }
      }

      .section {
        padding: 80px 0 20px;
      }

      .section-title {
        font-size: 34px;
        margin: 0 0 12px;
        text-align: center;
      }

      .section-text {
        text-align: center;
        color: var(--muted-2);
        max-width: 760px;
        margin: 0 auto 30px;
        line-height: 1.7;
      }

      .grid-3,
      .grid-4 {
        display: grid;
        gap: 20px;
      }

      .grid-3 {
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }

      .grid-4 {
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      }

      .card,
      .card-soft {
        border-radius: 18px;
        padding: 24px;
      }

      .card {
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
      }

      .card-soft {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
      }

      .card h3,
      .card-soft h3 {
        margin: 0 0 12px;
        font-size: 20px;
      }

      .card p,
      .card-soft p {
        margin: 0;
        color: var(--muted);
        line-height: 1.7;
      }

      .panel {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 22px;
        padding: 34px;
      }

      .center {
        text-align: center;
      }

      .footer {
        padding: 50px 0 10px;
        text-align: center;
        color: #9f96b7;
        font-size: 14px;
      }

      @media (max-width: 980px) {
        .hero {
          grid-template-columns: 1fr;
          text-align: center;
          min-height: auto;
        }

        .hero-copy {
          max-width: 760px;
          margin: 0 auto;
        }

        .hero-text {
          margin-left: auto;
          margin-right: auto;
        }

        .hero-buttons {
          justify-content: center;
        }

        .hero-visual {
          min-height: 480px;
          order: -1;
        }

        .globe-wrap {
          transform: scale(0.88);
        }
      }

      @media (max-width: 640px) {
        .container {
          padding: 24px 16px 70px;
        }

        .brand {
          font-size: 20px;
        }

        .nav {
          gap: 10px;
        }

        .hero-title {
          font-size: 42px;
        }

        .hero-text {
          font-size: 18px;
        }

        .section-title {
          font-size: 30px;
        }

        .panel {
          padding: 24px;
        }

        .hero-visual {
          min-height: 370px;
        }

        .globe-wrap {
          transform: scale(0.68);
        }
      }
    </style>
  </head>

  <body>
    <div class="page-grid"></div>
    <div class="page-glow"></div>

    <div class="container">
      <header class="site-header">
        <div class="brand">Vincson Technologies</div>

        <nav class="nav">
          <a class="glow-link nav-link" href="#services">Services</a>
          <a class="glow-link nav-link" href="#who-we-help">Who We Help</a>
          <a class="glow-link nav-link" href="#why-vincson-technologies">Why Vincson Technologies</a>
          <a class="glow-link nav-link" href="#alerts">Alerts</a>
          <a class="glow-link nav-link" href="#contact">Contact</a>
        </nav>
      </header>

      <section class="hero">
        <div class="hero-copy">
          <div class="eyebrow">AI-Powered Security</div>

          <h1 class="hero-title">Cybersecurity for Small Businesses</h1>

          <p class="hero-text">
            Vincson Technologies helps businesses reduce risk with practical security guidance,
            stronger threat visibility, and modern defense support built for today's evolving cyber threats.
          </p>

          <div class="hero-buttons">
            <a class="glow-link btn-primary" href="#contact">Request Consultation</a>
            <a class="glow-link btn-secondary" href="#services">View Services</a>
          </div>
        </div>

        <div class="hero-visual">
          <div class="hero-stars"></div>

          <div class="globe-wrap">
            <div class="globe-aura"></div>

            <div class="orbit orbit-one"></div>
            <div class="orbit orbit-two"></div>
            <div class="orbit orbit-three"></div>
            <div class="orbit orbit-four"></div>
            <div class="orbit orbit-five"></div>

            <div class="data-line line-1"></div>
            <div class="data-line line-2"></div>
            <div class="data-line line-3"></div>

            <div class="globe">
              <div class="continent europe"></div>
              <div class="continent africa"></div>
              <div class="continent middle-east"></div>
              <div class="continent india"></div>
              <div class="continent madagascar"></div>
              <div class="globe-highlight"></div>
            </div>
          </div>
        </div>
      </section>

      <section id="services" class="section" style="padding-top:30px;">
        <h2 class="section-title">Services</h2>

        <p class="section-text">
          Focused cybersecurity support designed to help organizations strengthen defenses without enterprise-level complexity.
        </p>

        <div class="grid-3">
          <div class="card">
            <h3>Threat Monitoring</h3>
            <p>
              Ongoing visibility into suspicious activity, potential weaknesses, and signs your environment may be exposed.
            </p>
          </div>

          <div class="card">
            <h3>Security Assessments</h3>
            <p>
              Review networks, devices, accounts, and business tools to identify gaps before attackers exploit them.
            </p>
          </div>

          <div class="card">
            <h3>AI-Enhanced Defense</h3>
            <p>
              Use modern workflows and intelligent security processes to keep pace with increasingly automated threats.
            </p>
          </div>
        </div>
      </section>

      <section id="who-we-help" class="section">
        <h2 class="section-title">Who We Help</h2>

        <p class="section-text">
          Vincson Technologies is built for organizations that need stronger security without unnecessary complexity.
        </p>

        <div class="grid-4">
          <div class="card-soft center">
            <h3>Small Businesses</h3>
            <p>Businesses that need practical protection without enterprise overhead.</p>
          </div>

          <div class="card-soft center">
            <h3>Property Management</h3>
            <p>Firms managing sensitive tenant, payment, and operational data.</p>
          </div>

          <div class="card-soft center">
            <h3>Professional Offices</h3>
            <p>Teams that depend on email, cloud platforms, and client confidentiality.</p>
          </div>

          <div class="card-soft center">
            <h3>Local Service Businesses</h3>
            <p>Organizations using connected devices, online accounts, and payment systems every day.</p>
          </div>
        </div>
      </section>

      <section id="why-vincson-technologies" class="section">
        <div class="panel">
          <h2 class="section-title" style="margin-bottom:18px;">Why Vincson Technologies</h2>

          <div class="grid-3" style="gap:18px; margin-top:24px;">
            <div class="card-soft">
              <h3>Practical Security</h3>
              <p>
                Focus on real protection and real risk reduction instead of unnecessary complexity.
              </p>
            </div>

            <div class="card-soft">
              <h3>Modern Defensive Thinking</h3>
              <p>
                Built around current threats, modern business tools, and AI-enhanced defensive workflows.
              </p>
            </div>

            <div class="card-soft">
              <h3>Built for Small Business Reality</h3>
              <p>
                Designed for organizations that need stronger security without enterprise pricing or confusion.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="alerts" class="section">
        <div class="panel center">
          <h2 class="section-title" style="margin-bottom:14px;">Threat Alerts & Cybersecurity Tips</h2>

          <p class="section-text" style="margin-bottom:24px;">
            Follow Vincson Technologies on Instagram for threat alerts, cybersecurity tips, and security awareness content focused on today's digital risks.
          </p>

          <a
            class="glow-link btn-primary"
            href="https://www.instagram.com/vincsontechnologies/"
            target="_blank"
            rel="noopener noreferrer"
          >
            Follow on Instagram
          </a>
        </div>
      </section>

      <section id="contact" class="section center" style="padding-bottom:10px;">
        <h2 class="section-title" style="margin-bottom:14px;">Ready to strengthen your security?</h2>

        <p class="section-text" style="max-width:680px; margin-bottom:26px;">
          Start the conversation and find out how Vincson Technologies can help your business improve visibility, reduce exposure, and build a stronger security posture.
        </p>

        <a class="glow-link btn-primary" href="mailto:VincsonTechnologies@gmail.com">
          Contact Vincson Technologies
        </a>
      </section>

      <footer class="footer">
        © 2026 Vincson Technologies. All rights reserved.
      </footer>
    </div>
  </body>
</html>
