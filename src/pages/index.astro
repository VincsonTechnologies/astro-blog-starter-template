---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vincson Technologies</title>

    <style>
      :root {
        --bg-1: #040407;
        --bg-2: #090512;
        --bg-3: #12091f;
        --text: #ffffff;
        --muted: #d8d0eb;
        --muted-2: #d3cae8;
        --purple: #7b2cff;
        --purple-2: #b56cff;
        --purple-soft: rgba(170, 110, 255, 0.45);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Arial, sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at 15% 20%, rgba(125, 55, 255, 0.14), transparent 30%),
          radial-gradient(circle at 85% 70%, rgba(95, 35, 255, 0.1), transparent 28%),
          linear-gradient(135deg, var(--bg-1) 0%, var(--bg-2) 45%, var(--bg-3) 100%);
        overflow-x: hidden;
      }

      .page-grid {
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
        z-index: 0;
      }

      .page-glow {
        position: fixed;
        top: -140px;
        right: -140px;
        width: 440px;
        height: 440px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(165,100,255,.16), transparent 68%);
        filter: blur(22px);
        pointer-events: none;
        z-index: 0;
      }

      .container {
        position: relative;
        z-index: 1;
        max-width: 1180px;
        margin: 0 auto;
        padding: 32px 20px 80px;
      }

      .site-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        padding: 8px 0 30px;
      }

      .brand {
        font-size: 22px;
        font-weight: 700;
        letter-spacing: .4px;
      }

      .nav {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
        font-size: 14px;
      }

      .glow-link {
        transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease, color 0.25s ease;
      }

      .glow-link:hover {
        box-shadow:
          0 0 18px rgba(160, 95, 255, 0.45),
          0 0 36px rgba(160, 95, 255, 0.22);
        transform: translateY(-2px);
      }

      .glow-link:active {
        box-shadow:
          0 0 28px rgba(190, 130, 255, 0.72);
        transform: scale(0.98);
      }

      .nav-link {
        color: #e1d2ff;
        text-decoration: none;
        padding: 6px 8px;
        border-radius: 8px;
      }

      .hero {
        min-height: 82vh;
        display: grid;
        grid-template-columns: 1.02fr 0.98fr;
        align-items: center;
        gap: 28px;
        padding: 10px 0 30px;
      }

      .hero-copy {
        max-width: 620px;
      }

      .eyebrow {
        display: inline-block;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #ceb5ff;
        margin-bottom: 18px;
      }

      .hero-title {
        font-size: clamp(38px, 6vw, 68px);
        line-height: 1.05;
        margin: 0 0 20px;
      }

      .hero-text {
        font-size: 20px;
        line-height: 1.7;
        color: #ddd6f3;
        max-width: 760px;
        margin: 0 0 34px;
      }

      .hero-buttons {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
      }

      .btn-primary,
      .btn-secondary {
        text-decoration: none;
        padding: 14px 24px;
        border-radius: 12px;
        font-weight: 700;
        display: inline-block;
      }

      .btn-primary {
        background: linear-gradient(135deg, var(--purple), var(--purple-2));
        color: white;
      }

      .btn-secondary {
        color: white;
        border: 1px solid rgba(255,255,255,.12);
        background: rgba(255,255,255,.04);
      }

      .hero-visual {
        position: relative;
        min-height: 560px;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: visible;
      }

      .hero-stars {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 20% 20%, rgba(255,255,255,.9) 0 1px, transparent 2px),
          radial-gradient(circle at 80% 15%, rgba(255,255,255,.7) 0 1px, transparent 2px),
          radial-gradient(circle at 70% 40%, rgba(255,255,255,.6) 0 1px, transparent 2px),
          radial-gradient(circle at 35% 65%, rgba(255,255,255,.7) 0 1px, transparent 2px),
          radial-gradient(circle at 85% 80%, rgba(255,255,255,.85) 0 1px, transparent 2px),
          radial-gradient(circle at 10% 75%, rgba(255,255,255,.75) 0 1px, transparent 2px);
        opacity: .55;
        animation: twinkle 6s ease-in-out infinite alternate;
        pointer-events: none;
      }

      @keyframes twinkle {
        from { opacity: .35; }
        to { opacity: .72; }
      }

      .globe-wrap {
        position: relative;
        width: 500px;
        height: 500px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .globe-aura {
        position: absolute;
        width: 520px;
        height: 520px;
        border-radius: 50%;
        background:
          radial-gradient(circle, rgba(170, 110, 255, .18) 0%, rgba(170, 110, 255, .08) 38%, transparent 72%);
        filter: blur(22px);
        animation: pulseAura 4.8s ease-in-out infinite;
      }

      @keyframes pulseAura {
        0%, 100% { transform: scale(0.98); opacity: .82; }
        50% { transform: scale(1.03); opacity: 1; }
      }

      .globe-shell {
        position: relative;
        width: 370px;
        height: 370px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .globe {
        position: relative;
        width: 370px;
        height: 370px;
        border-radius: 50%;
        background:
          radial-gradient(circle at 50% 70%, rgba(255,255,255,.28), transparent 20%),
          radial-gradient(circle at 48% 58%, rgba(205, 145, 255, .26), rgba(104, 38, 170, .18) 45%, rgba(18, 8, 34, .18) 66%, rgba(7, 4, 14, .78) 100%),
          linear-gradient(135deg, rgba(79, 26, 140, .88), rgba(40, 11, 78, .95));
        border: 1px solid rgba(230, 195, 255, .24);
        box-shadow:
          inset 0 0 40px rgba(255,255,255,.08),
          0 0 38px rgba(167, 98, 255, .22);
        overflow: hidden;
        animation: globeSpin 26s linear infinite;
      }

      @keyframes globeSpin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      .globe::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background:
          repeating-linear-gradient(
            90deg,
            rgba(255,255,255,0.00) 0px,
            rgba(255,255,255,0.00) 16px,
            rgba(237,210,255,0.09) 17px,
            rgba(255,255,255,0.00) 18px
          ),
          repeating-linear-gradient(
            0deg,
            rgba(255,255,255,0.00) 0px,
            rgba(255,255,255,0.00) 16px,
            rgba(237,210,255,0.07) 17px,
            rgba(255,255,255,0.00) 18px
          );
        mix-blend-mode: screen;
        opacity: .72;
      }

      .globe::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background:
          radial-gradient(circle at 34% 26%, rgba(255,255,255,.34), transparent 14%),
          radial-gradient(circle at 48% 45%, rgba(255,255,255,.06), transparent 42%),
          radial-gradient(circle at 52% 88%, rgba(255,255,255,.48), transparent 14%);
        filter: blur(5px);
        opacity: .92;
      }

      .orbit {
        position: absolute;
        border: 2px solid rgba(225, 180, 255, 0.76);
        border-radius: 50%;
        box-shadow: 0 0 22px rgba(188, 120, 255, 0.28);
        pointer-events: none;
      }

      .orbit::after {
        content: "";
        position: absolute;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,255,.98) 0%, rgba(230,190,255,.94) 45%, rgba(230,190,255,.12) 100%);
        box-shadow: 0 0 18px rgba(210, 150, 255, 0.8);
      }

      .orbit-one {
        width: 435px;
        height: 150px;
        animation: orbitSpin 10s linear infinite;
      }

      .orbit-one::after {
        top: 8px;
        left: 52px;
      }

      .orbit-two {
        width: 445px;
        height: 182px;
        transform: rotate(58deg);
        animation: orbitSpin 13s linear infinite reverse;
      }

      .orbit-two::after {
        bottom: 16px;
        right: 84px;
      }

      .orbit-three {
        width: 452px;
        height: 125px;
        transform: rotate(-24deg);
        animation: orbitSpin 11s linear infinite;
      }

      .orbit-three::after {
        top: 24px;
        right: 58px;
      }

      .orbit-four {
        width: 396px;
        height: 255px;
        transform: rotate(90deg);
        animation: orbitSpin 15s linear infinite reverse;
        opacity: .9;
      }

      .orbit-four::after {
        left: 66px;
        top: 34px;
      }

      .orbit-five {
        width: 335px;
        height: 335px;
        transform: rotate(20deg);
        border-color: rgba(225,180,255,0.34);
        animation: orbitSpin 18s linear infinite;
      }

      .orbit-five::after {
        right: 52px;
        top: 42px;
      }

      @keyframes orbitSpin {
        from { transform: rotate(var(--start-rotation, 0deg)); }
        to { transform: rotate(calc(var(--start-rotation, 0deg) + 360deg)); }
      }

      .orbit-one { --start-rotation: 0deg; }
      .orbit-two { --start-rotation: 58deg; }
      .orbit-three { --start-rotation: -24deg; }
      .orbit-four { --start-rotation: 90deg; }
      .orbit-five { --start-rotation: 20deg; }

      .data-line {
        position: absolute;
        height: 2px;
        background: linear-gradient(90deg, transparent, rgba(235, 205, 255, .96), transparent);
        transform-origin: left center;
        opacity: .88;
        pointer-events: none;
        box-shadow: 0 0 10px rgba(215, 160, 255, .25);
      }

      .data-line::after {
        content: "";
        position: absolute;
        top: 50%;
        right: 18%;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        transform: translateY(-50%);
        background: rgba(255,255,255,.96);
        box-shadow: 0 0 16px rgba(220, 165, 255, 0.82);
        animation: pulseDot 1.5s ease-in-out infinite;
      }

      @keyframes pulseDot {
        0%, 100% { transform: translateY(-50%) scale(0.9); opacity: .75; }
        50% { transform: translateY(-50%) scale(1.15); opacity: 1; }
      }

      .line-1 {
        width: 305px;
        top: 154px;
        left: 94px;
        transform: rotate(15deg);
        animation: lineShift1 4.6s ease-in-out infinite;
      }

      .line-2 {
        width: 310px;
        top: 220px;
        left: 84px;
        transform: rotate(-18deg);
        animation: lineShift2 5.2s ease-in-out infinite;
      }

      .line-3 {
        width: 250px;
        top: 276px;
        left: 126px;
        transform: rotate(26deg);
        animation: lineShift3 4.9s ease-in-out infinite;
      }

      @keyframes lineShift1 {
        0%, 100% { transform: rotate(15deg) translateX(0px); opacity: .72; }
        50% { transform: rotate(15deg) translateX(8px); opacity: 1; }
      }

      @keyframes lineShift2 {
        0%, 100% { transform: rotate(-18deg) translateX(0px); opacity: .72; }
        50% { transform: rotate(-18deg) translateX(-10px); opacity: 1; }
      }

      @keyframes lineShift3 {
        0%, 100% { transform: rotate(26deg) translateX(0px); opacity: .68; }
        50% { transform: rotate(26deg) translateX(10px); opacity: 1; }
      }

      .section {
        padding: 80px 0 20px;
      }

      .section-title {
        font-size: 34px;
        margin: 0 0 12px;
        text-align: center;
      }

      .section-text {
        text-align: center;
        color: var(--muted-2);
        max-width: 760px;
        margin: 0 auto 30px;
        line-height: 1.7;
      }

      .grid-3,
      .grid-4 {
        display: grid;
        gap: 20px;
      }

      .grid-3 {
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }

      .grid-4 {
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      }

      .card,
      .card-soft {
        border-radius: 18px;
        padding: 24px;
      }

      .card {
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
      }

      .card-soft {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
      }

      .card h3,
      .card-soft h3 {
        margin: 0 0 12px;
        font-size: 20px;
      }

      .card p,
      .card-soft p {
        margin: 0;
        color: var(--muted);
        line-height: 1.7;
      }

      .panel {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 22px;
        padding: 34px;
      }

      .center {
        text-align: center;
      }

      .footer {
        padding: 50px 0 10px;
        text-align: center;
        color: #9f96b7;
        font-size: 14px;
      }

      @media (max-width: 980px) {
        .hero {
          grid-template-columns: 1fr;
          text-align: center;
          min-height: auto;
        }

        .hero-copy {
          max-width: 760px;
          margin: 0 auto;
        }

        .hero-text {
          margin-left: auto;
          margin-right: auto;
        }

        .hero-buttons {
          justify-content: center;
        }

        .hero-visual {
          min-height: 480px;
          order: -1;
        }

        .globe-wrap {
          transform: scale(0.88);
        }
      }

      @media (max-width: 640px) {
        .container {
          padding: 24px 16px 70px;
        }

        .brand {
          font-size: 20px;
        }

        .nav {
          gap: 10px;
        }

        .hero-title {
          font-size: 42px;
        }

        .hero-text {
          font-size: 18px;
        }

        .section-title {
          font-size: 30px;
        }

        .panel {
          padding: 24px;
        }

        .hero-visual {
          min-height: 370px;
        }

        .globe-wrap {
          transform: scale(0.68);
        }
      }
    </style>
  </head>

  <body>
    <div class="page-grid"></div>
    <div class="page-glow"></div>

    <div class="container">
      <header class="site-header">
        <div class="brand">Vincson Technologies</div>

        <nav class="nav">
          <a class="glow-link nav-link" href="#services">Services</a>
          <a class="glow-link nav-link" href="#who-we-help">Who We Help</a>
          <a class="glow-link nav-link" href="#why-vincson-technologies">Why Vincson Technologies</a>
          <a class="glow-link nav-link" href="#alerts">Alerts</a>
          <a class="glow-link nav-link" href="#contact">Contact</a>
        </nav>
      </header>

      <section class="hero">
        <div class="hero-copy">
          <div class="eyebrow">AI-Powered Security</div>

          <h1 class="hero-title">Cybersecurity for Small Businesses</h1>

          <p class="hero-text">
            Vincson Technologies helps businesses reduce risk with practical security guidance,
            stronger threat visibility, and modern defense support built for today's evolving cyber threats.
          </p>

          <div class="hero-buttons">
            <a class="glow-link btn-primary" href="#contact">Request Consultation</a>
            <a class="glow-link btn-secondary" href="#services">View Services</a>
          </div>
        </div>

        <div class="hero-visual">
          <div class="hero-stars"></div>

          <div class="globe-wrap">
            <div class="globe-aura"></div>

            <div class="orbit orbit-one"></div>
            <div class="orbit orbit-two"></div>
            <div class="orbit orbit-three"></div>
            <div class="orbit orbit-four"></div>
            <div class="orbit orbit-five"></div>

            <div class="data-line line-1"></div>
            <div class="data-line line-2"></div>
            <div class="data-line line-3"></div>

            <div class="globe-shell">
              <div class="globe"></div>
            </div>
          </div>
        </div>
      </section>

      <section id="services" class="section" style="padding-top:30px;">
        <h2 class="section-title">Services</h2>

        <p class="section-text">
          Focused cybersecurity support designed to help organizations strengthen defenses without enterprise-level complexity.
        </p>

        <div class="grid-3">
          <div class="card">
            <h3>Threat Monitoring</h3>
            <p>
              Ongoing visibility into suspicious activity, potential weaknesses, and signs your environment may be exposed.
            </p>
          </div>

          <div class="card">
            <h3>Security Assessments</h3>
            <p>
              Review networks, devices, accounts, and business tools to identify gaps before attackers exploit them.
            </p>
          </div>

          <div class="card">
            <h3>AI-Enhanced Defense</h3>
            <p>
              Use modern workflows and intelligent security processes to keep pace with increasingly automated threats.
            </p>
          </div>
        </div>
      </section>

      <section id="who-we-help" class="section">
        <h2 class="section-title">Who We Help</h2>

        <p class="section-text">
          Vincson Technologies is built for organizations that need stronger security without unnecessary complexity.
        </p>

        <div class="grid-4">
          <div class="card-soft center">
            <h3>Small Businesses</h3>
            <p>Businesses that need practical protection without enterprise overhead.</p>
          </div>

          <div class="card-soft center">
            <h3>Property Management</h3>
            <p>Firms managing sensitive tenant, payment, and operational data.</p>
          </div>

          <div class="card-soft center">
            <h3>Professional Offices</h3>
            <p>Teams that depend on email, cloud platforms, and client confidentiality.</p>
          </div>

          <div class="card-soft center">
            <h3>Local Service Businesses</h3>
            <p>Organizations using connected devices, online accounts, and payment systems every day.</p>
          </div>
        </div>
      </section>

      <section id="why-vincson-technologies" class="section">
        <div class="panel">
          <h2 class="section-title" style="margin-bottom:18px;">Why Vincson Technologies</h2>

          <div class="grid-3" style="gap:18px; margin-top:24px;">
            <div class="card-soft">
              <h3>Practical Security</h3>
              <p>
                Focus on real protection and real risk reduction instead of unnecessary complexity.
              </p>
            </div>

            <div class="card-soft">
              <h3>Modern Defensive Thinking</h3>
              <p>
                Built around current threats, modern business tools, and AI-enhanced defensive workflows.
              </p>
            </div>

            <div class="card-soft">
              <h3>Built for Small Business Reality</h3>
              <p>
                Designed for organizations that need stronger security without enterprise pricing or confusion.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="alerts" class="section">
        <div class="panel center">
          <h2 class="section-title" style="margin-bottom:14px;">Threat Alerts & Cybersecurity Tips</h2>

          <p class="section-text" style="margin-bottom:24px;">
            Follow Vincson Technologies on Instagram for threat alerts, cybersecurity tips, and security awareness content focused on today's digital risks.
          </p>

          <a
            class="glow-link btn-primary"
            href="https://www.instagram.com/vincsontechnologies/"
            target="_blank"
            rel="noopener noreferrer"
          >
            Follow on Instagram
          </a>
        </div>
      </section>

      <section id="contact" class="section center" style="padding-bottom:10px;">
        <h2 class="section-title" style="margin-bottom:14px;">Ready to strengthen your security?</h2>

        <p class="section-text" style="max-width:680px; margin-bottom:26px;">
          Start the conversation and find out how Vincson Technologies can help your business improve visibility, reduce exposure, and build a stronger security posture.
        </p>

        <a class="glow-link btn-primary" href="mailto:VincsonTechnologies@gmail.com">
          Contact Vincson Technologies
        </a>
      </section>

      <footer class="footer">
        © 2026 Vincson Technologies. All rights reserved.
      </footer>
    </div>
  </body>
</html>
