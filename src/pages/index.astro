<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Vincson Technologies</title>

<style>
:root{
--bg:#05050a;
--text:#ffffff;
--muted:#d8d0eb;
--muted2:#b8afcf;
--purple:#2b1740;
--purple2:#462263;
}

*{
box-sizing:border-box;
}

html{
scroll-behavior:smooth;
}

body{
margin:0;
font-family:Arial,sans-serif;
color:var(--text);
background:var(--bg);
overflow-x:hidden;
}

.parallax-bg{
position:fixed;
inset:0;
z-index:-3;
background:
linear-gradient(rgba(18,8,38,.72),rgba(10,5,20,.82)),
url('/cloud-bg.jpg');
background-size:cover;
background-position:center;
background-repeat:no-repeat;
transform:scale(1.08);
animation:drift 30s ease-in-out infinite alternate;
}

@keyframes drift{
0%{transform:scale(1.08) translate3d(0,0,0);}
50%{transform:scale(1.12) translate3d(-18px,-10px,0);}
100%{transform:scale(1.08) translate3d(18px,10px,0);}
}

.page-glow{
position:fixed;
top:-120px;
right:-120px;
width:420px;
height:420px;
border-radius:50%;
background:radial-gradient(circle, rgba(48,18,74,.26), rgba(20,10,30,.10), transparent 70%);
filter:blur(42px);
z-index:-2;
pointer-events:none;
}

.center-pulse{
position:fixed;
left:72%;
top:30%;
transform:translate(-50%,-50%);
width:320px;
height:320px;
border-radius:50%;
background:radial-gradient(circle, rgba(95,40,170,.14), rgba(34,12,54,.08), transparent 70%);
filter:blur(28px);
animation:pulse 5s ease-in-out infinite;
z-index:-1;
pointer-events:none;
}

@keyframes pulse{
0%,100%{transform:translate(-50%,-50%) scale(.94); opacity:.75;}
50%{transform:translate(-50%,-50%) scale(1.08); opacity:1;}
}

.container{
max-width:1220px;
margin:auto;
padding:28px 20px 90px;
position:relative;
z-index:3;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
gap:16px;
flex-wrap:wrap;
padding-bottom:26px;
}

.brand{
font-size:23px;
font-weight:700;
letter-spacing:.2px;
}

nav{
display:flex;
gap:12px;
flex-wrap:wrap;
}

.glow-link{
transition:transform .25s ease, box-shadow .25s ease, border-color .25s ease;
}

.glow-link:hover{
transform:translateY(-2px);
box-shadow:
0 0 18px rgba(95,55,145,.40),
0 0 32px rgba(95,55,145,.18);
}

.glow-link:active{
transform:scale(.98);
box-shadow:
0 0 24px rgba(130,85,190,.45);
}

.nav-link{
text-decoration:none;
color:white;
padding:12px 18px;
border-radius:12px;
font-weight:700;
border:1px solid rgba(255,255,255,.09);
background:rgba(15,10,24,.72);
backdrop-filter:blur(10px);
}

.hero{
min-height:82vh;
display:grid;
grid-template-columns:1.05fr .95fr;
gap:34px;
align-items:center;
padding:30px 0 10px;
}

.hero-copy{
max-width:620px;
}

.eyebrow{
display:inline-block;
font-size:13px;
letter-spacing:2px;
text-transform:uppercase;
color:#cba9ff;
margin-bottom:18px;
}

.hero-title{
font-size:clamp(44px,6.2vw,78px);
line-height:1.01;
margin:0 0 20px;
font-weight:800;
}

.hero-title .accent{
color:#b775ff;
}

.hero-text{
font-size:19px;
line-height:1.75;
color:var(--muted);
margin:0 0 30px;
max-width:580px;
}

.hero-buttons{
display:flex;
gap:14px;
flex-wrap:wrap;
margin-bottom:28px;
}

.btn-primary,
.btn-secondary{
display:inline-block;
padding:14px 24px;
border-radius:12px;
text-decoration:none;
font-weight:700;
}

.btn-primary{
background:linear-gradient(135deg,var(--purple),var(--purple2));
border:1px solid rgba(130,85,180,.25);
box-shadow:inset 0 1px 0 rgba(255,255,255,.04);
color:white;
}

.btn-secondary{
background:rgba(15,10,24,.72);
border:1px solid rgba(255,255,255,.10);
color:white;
}

.proof-strip{
display:flex;
flex-wrap:wrap;
gap:10px;
}

.proof-pill{
padding:10px 14px;
border-radius:999px;
background:rgba(15,10,24,.72);
border:1px solid rgba(255,255,255,.08);
color:#ddd7f1;
font-size:14px;
}

.hero-visual{
position:relative;
min-height:560px;
display:flex;
align-items:center;
justify-content:center;
}

.visual-card{
width:min(100%,520px);
padding:22px;
border-radius:28px;
background:rgba(10,8,18,.66);
border:1px solid rgba(255,255,255,.08);
box-shadow:
0 20px 60px rgba(0,0,0,.34),
0 0 40px rgba(92,34,152,.10);
backdrop-filter:blur(14px);
transform:none;
transition:
transform .35s ease,
box-shadow .35s ease,
border-color .35s ease;
}

.visual-card:hover{
transform:translateY(-8px) scale(1.01);
border-color:rgba(180,120,255,.22);
box-shadow:
0 28px 70px rgba(0,0,0,.42),
0 0 50px rgba(110,55,190,.18);
}

.visual-top{
display:grid;
grid-template-columns:1.1fr .9fr;
gap:16px;
margin-bottom:16px;
}

.visual-panel{
border-radius:22px;
background:linear-gradient(180deg, rgba(23,16,35,.95), rgba(12,9,20,.92));
border:1px solid rgba(255,255,255,.06);
padding:22px;
min-height:220px;
position:relative;
overflow:hidden;
}

.visual-panel::before{
content:"";
position:absolute;
inset:auto -40px -40px auto;
width:160px;
height:160px;
border-radius:50%;
background:radial-gradient(circle, rgba(118,60,200,.25), transparent 70%);
filter:blur(10px);
}

.visual-kicker{
font-size:13px;
letter-spacing:1.5px;
text-transform:uppercase;
color:#d0b2ff;
margin-bottom:14px;
}

.visual-title{
font-size:32px;
line-height:1.08;
font-weight:800;
margin:0 0 16px;
}

.visual-title .accent{
color:#b56cff;
}

.visual-list{
padding-left:18px;
margin:0;
color:#d8d0eb;
line-height:1.8;
font-size:14px;
}

.visual-art{
border-radius:22px;
background:linear-gradient(180deg, rgba(20,13,31,.96), rgba(12,9,20,.92));
border:1px solid rgba(255,255,255,.06);
min-height:220px;
position:relative;
overflow:hidden;
display:flex;
align-items:center;
justify-content:center;
}

.lock-art{
padding:0;
}

.lock-image{
width:100%;
height:100%;
object-fit:cover;
display:block;
filter:
brightness(1)
contrast(1.02)
saturate(1.02);
}

/* subtle glow coming off the lock image */
.lock-art::before{
content:"";
position:absolute;
inset:0;
background:
radial-gradient(circle at 58% 48%, rgba(120,210,255,.18), transparent 20%),
radial-gradient(circle at 58% 48%, rgba(190,110,255,.14), transparent 32%);
pointer-events:none;
mix-blend-mode:screen;
animation:lockGlow 4.2s ease-in-out infinite;
}

@keyframes lockGlow{
0%,100%{opacity:.55; transform:scale(1);}
50%{opacity:.9; transform:scale(1.02);}
}

/* pulsing light lines over the card */
.lock-art::after{
content:"";
position:absolute;
inset:0;
background:
linear-gradient(100deg, transparent 0%, transparent 30%, rgba(145,220,255,.0) 42%, rgba(145,220,255,.65) 50%, rgba(190,120,255,.45) 53%, rgba(145,220,255,.0) 60%, transparent 72%, transparent 100%);
mix-blend-mode:screen;
opacity:.55;
animation:scanBeam 3.8s linear infinite;
pointer-events:none;
}

@keyframes scanBeam{
0%{transform:translateX(-120%) skewX(-18deg);}
100%{transform:translateX(120%) skewX(-18deg);}
}

/* extra radial pulse lines from lock center */
.lock-lines{
position:absolute;
inset:0;
pointer-events:none;
}

.lock-line{
position:absolute;
left:50%;
top:54%;
height:2px;
transform-origin:left center;
background:linear-gradient(90deg, rgba(145,220,255,.95), rgba(190,120,255,.78), transparent);
box-shadow:0 0 12px rgba(145,220,255,.35);
opacity:.75;
animation:pulseLine 2.8s ease-in-out infinite;
}

.lock-line:nth-child(1){width:120px; transform:rotate(-22deg); animation-delay:.0s;}
.lock-line:nth-child(2){width:130px; transform:rotate(-8deg); animation-delay:.3s;}
.lock-line:nth-child(3){width:128px; transform:rotate(8deg); animation-delay:.6s;}
.lock-line:nth-child(4){width:116px; transform:rotate(22deg); animation-delay:.9s;}

@keyframes pulseLine{
0%,100%{opacity:.28; transform-origin:left center;}
50%{opacity:.9;}
}

.visual-bottom{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:14px;
}

.stat-card{
padding:18px;
border-radius:18px;
background:linear-gradient(180deg, rgba(17,12,28,.95), rgba(10,8,18,.94));
border:1px solid rgba(255,255,255,.06);
}

.stat-dot{
width:12px;
height:12px;
border-radius:50%;
background:linear-gradient(135deg,#8f4fff,#c17aff);
box-shadow:0 0 18px rgba(145,80,255,.45);
margin-bottom:12px;
}

.stat-title{
font-size:15px;
font-weight:700;
margin-bottom:8px;
}

.stat-text{
font-size:13px;
line-height:1.6;
color:#d0c7e6;
}

.section{
padding:86px 0 10px;
}

.section-header{
text-align:center;
max-width:820px;
margin:0 auto 32px;
}

.section-title{
font-size:36px;
margin:0 0 14px;
}

.section-text{
color:var(--muted2);
line-height:1.75;
margin:0;
}

.grid-3,
.grid-4{
display:grid;
gap:20px;
}

.grid-3{
grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
}

.grid-4{
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
}

.card,
.card-soft{
border-radius:22px;
padding:24px;
background:linear-gradient(180deg, rgba(15,10,24,.78), rgba(12,9,20,.88));
border:1px solid rgba(255,255,255,.08);
backdrop-filter:blur(12px);
box-shadow:0 10px 34px rgba(0,0,0,.18);
}

.card-icon{
width:16px;
height:16px;
border-radius:50%;
background:linear-gradient(135deg,#8f4fff,#c17aff);
box-shadow:0 0 18px rgba(145,80,255,.45);
margin-bottom:14px;
}

.card h3,
.card-soft h3{
margin:0 0 12px;
font-size:20px;
}

.card p,
.card-soft p{
margin:0;
line-height:1.75;
color:#ddd7f1;
}

.panel{
padding:34px;
border-radius:26px;
background:linear-gradient(180deg, rgba(15,10,24,.76), rgba(10,8,18,.9));
border:1px solid rgba(255,255,255,.08);
backdrop-filter:blur(14px);
}

.center{
text-align:center;
}

footer{
padding:60px 0 10px;
text-align:center;
color:#aaa1c5;
}

@media(max-width:980px){
.hero{
grid-template-columns:1fr;
text-align:center;
}
.hero-copy{
max-width:780px;
margin:0 auto;
}
.hero-text{
margin-left:auto;
margin-right:auto;
}
.hero-buttons,
.proof-strip{
justify-content:center;
}
}

@media(max-width:640px){
nav{
justify-content:center;
}
.hero-title{
font-size:42px;
}
.hero-text{
font-size:18px;
}
.visual-top,
.visual-bottom{
grid-template-columns:1fr;
}
}
</style>
</head>

<body>

<div class="parallax-bg"></div>
<div class="center-pulse"></div>
<div class="page-glow"></div>

<div class="container">

<header>
<div class="brand">Vincson Technologies</div>

<nav>
